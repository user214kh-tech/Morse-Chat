-- Catbar Morse Code GUI
-- Body Morse: LAY = dot | SIT = dash
-- Send button ONLY, Enter does nothing

local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")
local player = Players.LocalPlayer

local MORSE = {}
MORSE.A=".-" MORSE.B="-..." MORSE.C="-.-." MORSE.D="-.."
MORSE.E="." MORSE.F="..-." MORSE.G="--." MORSE.H="...."
MORSE.I=".." MORSE.J=".---" MORSE.K="-.-" MORSE.L=".-.."
MORSE.M="--" MORSE.N="-." MORSE.O="---" MORSE.P=".--."
MORSE.Q="--.-" MORSE.R=".-." MORSE.S="..." MORSE.T="-"
MORSE.U="..-" MORSE.V="...-" MORSE.W=".--" MORSE.X="-..-"
MORSE.Y="-.--" MORSE.Z="--.."
MORSE["0"]="-----" MORSE["1"]=".----" MORSE["2"]="..---"
MORSE["3"]="...--" MORSE["4"]="....-" MORSE["5"]="....."
MORSE["6"]="-....." MORSE["7"]="--..." MORSE["8"]="---.."
MORSE["9"]="----." MORSE[" "]="/"

local MORSE_DECODE = {}
for k,v in pairs(MORSE) do MORSE_DECODE[v] = k end

local function toMorse(text)
    local out = {}
    for i=1,#text do
        local c = text:sub(i,i):upper()
        out[#out+1] = MORSE[c] or "?"
    end
    return table.concat(out, " ")
end

local function fromMorse(str)
    local out = {}
    for w in str:gmatch("[^ ]+") do
        if w == "/" then
            out[#out+1] = " "
        elseif MORSE_DECODE[w] then
            out[#out+1] = MORSE_DECODE[w]:lower()
        else
            out[#out+1] = "?"
        end
    end
    return table.concat(out)
end

local function looksLikeMorse(text)
    local d = select(2, text:gsub("%.", ""))
    local h = select(2, text:gsub("%-", ""))
    local t = #text:gsub("%s", "")
    return t > 0 and (d+h)/t >= 0.5
end

local SYM_GAP = 0.55
local LTR_GAP = 2.50
local WRD_GAP = 3.50
local R_LTR   = 1.6
local R_WRD   = 3.8   -- increased to prevent unwanted word spaces between letters
local R_MSG   = 6.0

local addToLog
local logFrame

local function makeDecoder()
    return {
        code="", letters={},
        lastSig=0, lastMove=0,
        layCD=false, sitCD=false,
    }
end

-- SENDER
local sendQueue = {}
local busy = false

local function getChar()
    return player.Character or player.CharacterAdded:Wait()
end

local function doLay()
    local char = getChar()
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end
    
    hum.PlatformStand = true
    root.CFrame = root.CFrame * CFrame.Angles(math.rad(90), 0, 0)
    task.wait(0.6)
    hum.PlatformStand = false
    
    -- Fix flipping when standing back up
    task.wait(0.1)
    local cf = root.CFrame
    local _, yaw, _ = cf:ToEulerAnglesXYZ()
    root.CFrame = CFrame.new(cf.Position) * CFrame.Angles(0, yaw, 0)
    
    task.wait(0.2)
end

local function doSit()
    local char = getChar()
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    hum.Sit = true
    task.wait(0.7)
    hum.Sit = false
    task.wait(0.3)
end

local function runLetter(letter)
    if letter == " " then
        task.wait(WRD_GAP)
        return
    end
    local code = MORSE[letter:upper()]
    if not code then task.wait(LTR_GAP); return end
    for i = 1, #code do
        local s = code:sub(i,i)
        if s == "." then doLay()
        elseif s == "-" then doSit() end
        if i < #code then task.wait(SYM_GAP) end
    end
    task.wait(LTR_GAP)
end

local function drainQueue()
    if busy then return end
    busy = true
    while #sendQueue > 0 do
        runLetter(table.remove(sendQueue, 1))
    end
    busy = false
end

local function bodyMorseSend(text)
    for i = 1, #text do
        sendQueue[#sendQueue+1] = text:sub(i,i)
    end
    task.spawn(drainQueue)
end

-- RECEIVER (other players)
local function hookPlayer(p)
    local function tryHook()
        local char = p.Character or p.CharacterAdded:Wait()
        local hum  = char:WaitForChild("Humanoid", 10)
        if not hum then return end
        local dec = makeDecoder()

        task.spawn(function()
            while hum and hum.Parent do
                task.wait(0.2)
                local now = tick()

                if dec.code ~= "" and dec.lastSig > 0 and (now - dec.lastSig) >= R_LTR then
                    local d = MORSE_DECODE[dec.code]
                    if d and d ~= " " then
                        dec.letters[#dec.letters+1] = d:lower()
                    end
                    dec.code = ""
                end

                if #dec.letters > 0 and dec.lastMove > 0 and (now - dec.lastMove) >= R_MSG then
                    if dec.code ~= "" then
                        local d = MORSE_DECODE[dec.code]
                        if d then dec.letters[#dec.letters+1] = d:lower() end
                        dec.code = ""
                    end
                    while #dec.letters > 0 and dec.letters[#dec.letters] == " " do
                        table.remove(dec.letters)
                    end
                    local msg = table.concat(dec.letters)
                    if msg ~= "" and addToLog then
                        addToLog(p.Name, msg, false, true)
                    end
                    dec.letters = {}
                end
            end
        end)

        local function checkWordGap()
            local now = tick()
            if #dec.letters > 0
            and dec.letters[#dec.letters] ~= " "
            and dec.lastMove > 0
            and (now - dec.lastMove) >= R_WRD then
                dec.letters[#dec.letters+1] = " "
            end
        end

        hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
            if hum.PlatformStand == true and not dec.layCD then
                dec.layCD = true
                checkWordGap()
                dec.code = dec.code .. "."
                dec.lastSig = tick()
                dec.lastMove = tick()
                task.delay(0.8, function() dec.layCD = false end)
            end
        end)

        hum.StateChanged:Connect(function(_, new)
            if new == Enum.HumanoidStateType.Seated and not dec.sitCD then
                dec.sitCD = true
                checkWordGap()
                dec.code = dec.code .. "-"
                dec.lastSig = tick()
                dec.lastMove = tick()
                task.delay(1.2, function() dec.sitCD = false end)
            end
        end)
    end
    task.spawn(tryHook)
    p.CharacterAdded:Connect(function() task.spawn(tryHook) end)
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= player then hookPlayer(p) end
end
Players.PlayerAdded:Connect(function(p)
    if p ~= player then hookPlayer(p) end
end)

-- SELF WATCHER
local selfDec   = makeDecoder()
local selfLabel = nil
local selfOn    = false

local function updateSelf()
    if not selfLabel then return end
    local built  = table.concat(selfDec.letters)
    local inprog = selfDec.code ~= "" and (" [" .. selfDec.code .. "]") or ""
    if not selfOn then
        selfLabel.Text = string.format(
            '<font color="#9B59B6">You (sent):</font>\n<font color="#aaaaaa"> they read: </font><font color="#E67E22">%s</font> <font color="#27AE60">checkmark</font>',
            built == "" and "?" or built)
        selfLabel.Text = selfLabel.Text:gsub("checkmark", string.char(226,156,147))
    else
        selfLabel.Text = string.format(
            '<font color="#9B59B6">You (sending...):</font>\n<font color="#aaaaaa"> they read: </font><font color="#E67E22">%s%s</font><font color="#FFAA00">|</font>',
            built, inprog)
    end
    if logFrame then
        task.defer(function()
            logFrame.CanvasPosition = Vector2.new(0, logFrame.AbsoluteCanvasSize.Y)
        end)
    end
end

local function startSelfWatch()
    selfDec = makeDecoder()
    selfOn  = true

    local f = Instance.new("Frame", logFrame)
    f.Size = UDim2.new(1,-6,0,0)
    f.AutomaticSize = Enum.AutomaticSize.Y
    f.BackgroundTransparency = 1

    selfLabel = Instance.new("TextLabel", f)
    selfLabel.Size = UDim2.new(1,0,0,0)
    selfLabel.AutomaticSize = Enum.AutomaticSize.Y
    selfLabel.BackgroundTransparency = 1
    selfLabel.TextWrapped = true
    selfLabel.TextXAlignment = Enum.TextXAlignment.Left
    selfLabel.RichText = true
    selfLabel.Font = Enum.Font.Gotham
    selfLabel.TextSize = 13
    selfLabel.Text = '<font color="#9B59B6">You (sending...):</font>\n<font color="#aaaaaa"> they read: </font><font color="#FFAA00">...</font>'

    task.defer(function()
        logFrame.CanvasPosition = Vector2.new(0, logFrame.AbsoluteCanvasSize.Y)
    end)
end

local function hookSelf()
    local char = player.Character or player.CharacterAdded:Wait()
    local hum  = char:WaitForChild("Humanoid", 10)
    if not hum then return end

    local function checkWordGapSelf()
        local now = tick()
        if #selfDec.letters > 0
        and selfDec.letters[#selfDec.letters] ~= " "
        and selfDec.lastMove > 0
        and (now - selfDec.lastMove) >= R_WRD then
            selfDec.letters[#selfDec.letters+1] = " "
        end
    end

    hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
        if not selfOn then return end
        if hum.PlatformStand == true and not selfDec.layCD then
            selfDec.layCD = true
            checkWordGapSelf()
            selfDec.code = selfDec.code .. "."
            selfDec.lastSig = tick()
            selfDec.lastMove = tick()
            updateSelf()
            task.delay(0.8, function() selfDec.layCD = false end)
        end
    end)

    hum.StateChanged:Connect(function(_, new)
        if not selfOn then return end
        if new == Enum.HumanoidStateType.Seated and not selfDec.sitCD then
            selfDec.sitCD = true
            checkWordGapSelf()
            selfDec.code = selfDec.code .. "-"
            selfDec.lastSig = tick()
            selfDec.lastMove = tick()
            updateSelf()
            task.delay(1.2, function() selfDec.sitCD = false end)
        end
    end)

    task.spawn(function()
        while true do
            task.wait(0.2)
            if not selfOn then continue end
            local now = tick()

            if selfDec.code ~= "" and selfDec.lastSig > 0 and (now - selfDec.lastSig) >= R_LTR then
                local d = MORSE_DECODE[selfDec.code]
                if d and d ~= " " then
                    selfDec.letters[#selfDec.letters+1] = d:lower()
                    updateSelf()
                end
                selfDec.code = ""
            end

            if #selfDec.letters > 0 and selfDec.lastMove > 0 and (now - selfDec.lastMove) >= R_MSG then
                if selfDec.code ~= "" then
                    local d = MORSE_DECODE[selfDec.code]
                    if d then selfDec.letters[#selfDec.letters+1] = d:lower() end
                    selfDec.code = ""
                end
                selfOn = false
                updateSelf()
                selfLabel = nil
            end
        end
    end)
end

task.spawn(hookSelf)
player.CharacterAdded:Connect(function() task.spawn(hookSelf) end)

